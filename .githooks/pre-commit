#!/usr/bin/env sh

CHANGED_JAVA_FILES=$(git diff --cached --name-only -- '*.java')

if [ -z "$CHANGED_JAVA_FILES" ]; then
  echo "No Java files changed. Skipping Checkstyle."
  exit 0
fi

echo "Running Checkstyle for the project (checking all files as a safety measure)..."
./mvnw -q checkstyle:check

if [ $? -ne 0 ]; then
    echo "❌ Checkstyle violations found. Please fix them before committing."
    exit 1
fi

echo "✅ Checkstyle passed."
exit 0
